DATABASE_URL=postgresql+asyncpg://oak:oak@localhost:5432/oak

# Public base URL of this API (Tink redirects here after bank auth)
BASE_URL=https://api.oakapp.dk

# Tink Open Banking
TINK_CLIENT_ID=
TINK_CLIENT_SECRET=
TINK_BASE_URL=https://api.tink.com

# Set to true to use in-memory sandbox (no real API calls)
TINK_SANDBOX=true

# Deep link scheme for redirecting back to the iOS app
IOS_CALLBACK_SCHEME=oak

DEBUG=true
